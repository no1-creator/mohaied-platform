// Mohaied Platform — Database Schema
// قاعدة بيانات منصة محايد

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  CLIENT
  PROVIDER
  SUPERVISOR
  ADMIN
  LEGAL_CONSULTANT
}

enum ProviderType {
  COMPANY
  FREELANCER
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_AGREEMENT
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
}

enum OfferStatus {
  DRAFT
  SUBMITTED
  REVISION_REQUESTED
  REVISED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum AgreementStatus {
  PENDING_CLIENT
  PENDING_PROVIDER
  CONFIRMED
  CANCELLED
  SUPERSEDED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
}

enum SupervisorAssignmentStatus {
  INVITED
  ACCEPTED
  DECLINED
  ACTIVE
  COMPLETED
  REMOVED
}

enum SupervisorReportStatus {
  DRAFT
  SUBMITTED
  APPROVED_DELIVERY
  NEEDS_REVISION
  NEEDS_CLARIFICATION
}

enum ComplaintType {
  DELIVERY_DELAY
  AGREEMENT_VIOLATION
  PAYMENT_ISSUE
  UNPROFESSIONAL
  OTHER
}

enum ComplaintStatus {
  OPEN
  AWAITING_RESPONSE
  UNDER_REVIEW
  IN_ARBITRATION
  RESOLVED
  REJECTED
  CLOSED
}

enum DecisionType {
  EXTEND_DURATION
  FAVOR_CLIENT
  FAVOR_PROVIDER
  AMICABLE
  OTHER
}

// ---- Monetization enums (جديد) ----

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum EscrowStatus {
  PENDING
  FUNDED
  RELEASED
  REFUNDED
  DISPUTED
}

enum InvoiceType {
  SUBSCRIPTION
  MILESTONE
  COMMISSION
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
  REFUNDED
}

// ==================== USERS ====================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  fullName     String
  role         UserRole
  avatarUrl    String?
 isVerified   Boolean  @default(false)
isActive     Boolean  @default(true)
isSuperAdmin Boolean  @default(false)
adminScopes  String?
createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

 providerProfile        ProviderProfile?
supervisorProfile      SupervisorProfile?
legalConsultantProfile LegalConsultantProfile?

  clientProjects   Project[] @relation("ClientProjects")
  providerProjects Project[] @relation("ProviderProjects")

  offers                Offer[]
  submissions           Submission[]
  supervisorAssignments SupervisorAssignment[]
  complaintsFiled       Complaint[]            @relation("ComplaintCreator")
  activityLogs          ActivityLog[]
  messages              Message[]

  subscriptions Subscription[]
  invoices      Invoice[]

  notifications Notification[]

  recommendationRequests RecommendationRequest[] @relation("ClientRecommendations")

  externalInvitations ExternalInvitation[] @relation("ClientInvitations")

  reviewsWritten  Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewTarget")
}

model ProviderProfile {
  id              String       @id @default(uuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id])
  type            ProviderType
  companyName     String?
  field           String
  bio             String?
  yearsExp        Int?
  teamSize        Int?
  city            String?
  phone           String?
  website         String?
  portfolioUrl    String?
  skills          String?
  commercialRegNo String?
  taxId           String?
  nationalId      String?
  logoUrl         String?
  coverUrl        String?
  portfolioImages String?
  linkedinUrl     String?
  whatsapp        String?
  rating          Float        @default(0)
   reviewsCount Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalConsultantProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  title            String
  field            String
  yearsExp         Int      @default(0)
  consultationRate Decimal  @default(0)
  bio              String?
  education        String?
  certifications   String?
  specialties      String?
  languages        String?
  city             String?
  phone            String?
  linkedinUrl      String?
  barAssociationNo String?
  rating           Float    @default(0)
  reviewsCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==================== PROJECTS ====================

model SupervisorProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  title          String
  field          String
  yearsExp       Int      @default(0)
  ratePerReview  Decimal  @default(0)
  bio            String?
  education      String?
  certifications String?
  specialties    String?
  languages      String?
  city           String?
  phone          String?
  linkedinUrl    String?
  membershipNo   String?
  rating         Float    @default(0)
  reviewsCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LegalConsultantProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  title            String
  field            String
  yearsExp         Int      @default(0)
  consultationRate Decimal  @default(0)
  bio              String?
  education        String?
  certifications   String?
  specialties      String?
  languages        String?
  city             String?
  phone            String?
  linkedinUrl      String?
  barAssociationNo String?
  rating           Float    @default(0)
  reviewsCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==================== PROJECTS ====================
model Project {
  id          String        @id @default(uuid())
  title       String
  field       String
  description String
  status      ProjectStatus @default(DRAFT)

  clientId String
  client   User   @relation("ClientProjects", fields: [clientId], references: [id])

  providerId String?
  provider   User?   @relation("ProviderProjects", fields: [providerId], references: [id])

  preferredProviderId String?
  budgetMin           Decimal?
  budgetMax           Decimal?
  durationDays        Int?

  offers                Offer[]
  agreement             Agreement?
  milestones            Milestone[]
  complaints            Complaint[]
  files                 FileAsset[]
  messages              Message[]
  supervisorAssignments SupervisorAssignment[]
  activityLogs          ActivityLog[]
  escrowTransactions    EscrowTransaction[]
  reviews               Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== OFFERS ====================

model Offer {
  id         String @id @default(uuid())
  projectId  String
  project    Project @relation(fields: [projectId], references: [id])
  providerId String
  provider   User    @relation(fields: [providerId], references: [id])

  status      OfferStatus @default(DRAFT)
  totalPrice  Decimal
  durationDays Int
  scope       String
  version     Int         @default(1)

 milestones  OfferMilestone[]
attachments OfferAttachment[]
agreement   Agreement?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model OfferAttachment {
  id        String   @id @default(uuid())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id])
  fileUrl   String?
  link      String?
  createdAt DateTime @default(now())
}
model OfferMilestone {
  id           String  @id @default(uuid())
  offerId      String
  offer        Offer   @relation(fields: [offerId], references: [id])
  title        String
  description  String
  price        Decimal
  durationDays Int
  orderIndex   Int
}

// ==================== AGREEMENT ====================

model Agreement {
  id        String  @id @default(uuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id])
  offerId   String  @unique
  offer     Offer   @relation(fields: [offerId], references: [id])

  status             AgreementStatus @default(PENDING_CLIENT)
  totalValue         Decimal
  durationDays       Int
  revisionPolicy     String?
  clientApprovedAt   DateTime?
  providerApprovedAt DateTime?
confirmedAt        DateTime?

// ---- العقد الإلكتروني وتوقيعه (جديد) ----
contractNumber   String?
contractBody     String?
clientSignName   String?
clientSignedAt   DateTime?
clientSignHash   String?
providerSignName String?
providerSignedAt DateTime?
providerSignHash String?
fullySignedAt    DateTime?

createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== MILESTONES & SUBMISSIONS ====================

model Milestone {
  id           String          @id @default(uuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id])
  title        String
  description  String
  value        Decimal
  durationDays Int
  orderIndex   Int
  status       MilestoneStatus @default(PENDING)
  dueDate      DateTime?

  submissions Submission[]
  escrow      EscrowTransaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Submission {
  id           String    @id @default(uuid())
  milestoneId  String
  milestone    Milestone @relation(fields: [milestoneId], references: [id])
  providerId   String
  provider     User      @relation(fields: [providerId], references: [id])
  notes        String
  externalLink String?
  reviewNotes  String?
  approved     Boolean?

   files       FileAsset[]
  attachments SubmissionAttachment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model SubmissionAttachment {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id])
  fileUrl      String?
  link         String?
  createdAt    DateTime   @default(now())
}
// ==================== SUPERVISOR ====================

model SupervisorAssignment {
  id           String                     @id @default(uuid())
  projectId    String
  project      Project                    @relation(fields: [projectId], references: [id])
  supervisorId String
  supervisor   User                       @relation(fields: [supervisorId], references: [id])
  status       SupervisorAssignmentStatus @default(INVITED)
  ratePerReview Decimal

  reports   SupervisorReport[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model SupervisorReport {
  id           String                 @id @default(uuid())
  assignmentId String
  assignment   SupervisorAssignment   @relation(fields: [assignmentId], references: [id])
  milestoneId  String?
  summary      String
  notes        String?
  status       SupervisorReportStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== COMPLAINTS ====================

model Complaint {
  id        String  @id @default(uuid())
  code      String  @unique
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  milestoneId String?
  creatorId String
  creator   User    @relation("ComplaintCreator", fields: [creatorId], references: [id])

  type         ComplaintType
  customType    String?
  arbitratorId String?
  status       ComplaintStatus @default(OPEN)
  details      String

  evidences ComplaintEvidence[]
  responses ComplaintResponse[]
  decision  Decision?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ComplaintEvidence {
  id          String    @id @default(uuid())
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  fileUrl     String?
  link        String?
  createdAt   DateTime  @default(now())
}

model ComplaintResponse {
  id          String    @id @default(uuid())
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  responderId String
  message     String
  createdAt   DateTime  @default(now())
}

model Decision {
  id          String       @id @default(uuid())
  complaintId String       @unique
  complaint   Complaint    @relation(fields: [complaintId], references: [id])
  type        DecisionType
  customType   String?
  reason      String
  decidedById String
  createdAt   DateTime     @default(now())
}

// ==================== FILES & CHAT & LOG ====================

model FileAsset {
  id           String      @id @default(uuid())
  name         String
  url          String
  mimeType     String?
  data         String?     // محتوى الملف base64 (جديد)
  size         Int?        // حجم الملف بالبايت (جديد)
  uploaderId   String?     // مين رفع الملف (جديد)
folder       String?     // مجلد الملف، مثلاً MEDIA لمكتبة الوسائط (جديد)
isPublic     Boolean     @default(false) // متاح للعرض العام بدون تسجيل دخول (جديد)
projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  createdAt    DateTime    @default(now())
}

model Message {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  senderId  String?
  sender    User?    @relation(fields: [senderId], references: [id])
  isSystem  Boolean  @default(false)
  content   String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}

// ==================== MONETIZATION (جديد) ====================

model PlatformSettings {
  id                    String   @id @default(uuid())
  defaultCommissionRate Decimal  @default(15)
  escrowEnabled         Boolean  @default(true)
  platformName          String   @default("محايد")
  supportEmail          String?
  updatedAt             DateTime @updatedAt
}

model SubscriptionPlan {
  id             String       @id @default(uuid())
  name           String
  description    String?
  price          Decimal      @default(0)
  billingCycle   BillingCycle @default(MONTHLY)
  commissionRate Decimal      @default(10)
  features       String?
  maxOffers      Int?
  isFeatured     Boolean      @default(false)
  isActive       Boolean      @default(true)
  orderIndex     Int          @default(0)

  // ---- مميزات الباقة القابلة للتفعيل (جديد) ----
  directoryPriority      Int     @default(0)
  badgeLabel             String?
  monthlyAdCredits       Int     @default(0)
  recommendationPriority Int     @default(0)
  teamSeats              Int     @default(1)
  analyticsAccess        Boolean @default(false)
  prioritySupport        Boolean @default(false)

  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  planId    String
  plan      SubscriptionPlan   @relation(fields: [planId], references: [id])
  status    SubscriptionStatus @default(PENDING)
  startedAt DateTime?
  expiresAt DateTime?
  autoRenew Boolean            @default(false)

  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model EscrowTransaction {
  id               String       @id @default(uuid())
  milestoneId      String       @unique
  milestone        Milestone    @relation(fields: [milestoneId], references: [id])
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id])
  amount           Decimal
  commissionRate   Decimal      @default(0)
  commissionAmount Decimal      @default(0)
  netAmount        Decimal      @default(0)
  status           EscrowStatus @default(PENDING)
  fundedAt         DateTime?
  releasedAt       DateTime?
  refundedAt       DateTime?

  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Invoice {
  id          String        @id @default(uuid())
  code        String        @unique
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  type        InvoiceType
  status      InvoiceStatus @default(UNPAID)
  amount      Decimal
  description String?

  subscriptionId String?
  subscription   Subscription?      @relation(fields: [subscriptionId], references: [id])
  escrowId       String?
  escrow         EscrowTransaction? @relation(fields: [escrowId], references: [id])

  issuedAt  DateTime  @default(now())
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ==================== DYNAMIC OPTION LISTS (جديد) ====================
// قوائم خيارات يتحكم فيها الأدمن (أنواع النزاع/القرار/التصنيفات… إلخ)

model OptionItem {
  id        String   @id @default(uuid())
  groupKey  String
  value     String
  label     String
  isActive  Boolean  @default(true)
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupKey, value])
}

model SiteContent {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  groupKey  String   @default("general")
  label     String?
  type      String   @default("text")
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdBanner {
  id                 String   @id @default(uuid())
  advertiserId       String?
  title              String
  subtitle           String?
  imageUrl           String?
  linkUrl            String?
  ctaLabel           String?
  placement          String   @default("HOME_TOP")
  status             String   @default("PENDING")
  amount             Float    @default(0)
  paid               Boolean  @default(false)
  priority           Int      @default(0)
  dailyImpressionCap Int      @default(0)
  impressionsToday   Int      @default(0)
  impressionDay      String?
  startDate          DateTime?
  endDate            DateTime?
  orderIndex         Int      @default(0)
  clicks             Int      @default(0)
  impressions        Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ==================== NOTIFICATIONS ====================

enum NotificationType {
  GENERAL
  OFFER
  PROJECT
  COMPLAINT
  MILESTONE
  SUPERVISOR
  SUBSCRIPTION
  AD
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType @default(GENERAL)
  title     String
  body      String?
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ==================== RECOMMENDATION REQUESTS (رشّحلي الأفضل) ====================

enum RecommendationStatus {
  PENDING
  IN_REVIEW
  RESPONDED
  CLOSED
}

model RecommendationRequest {
  id                     String               @id @default(uuid())
  clientId               String
  client                 User                 @relation("ClientRecommendations", fields: [clientId], references: [id])
  title                  String
  field                  String
  description            String
  budgetMin              Decimal?
  budgetMax              Decimal?
  durationDays           Int?
  status                 RecommendationStatus @default(PENDING)
  adminNote              String?
  recommendedProviderIds String[]             @default([])
  respondedById          String?
  respondedAt            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([clientId])
  @@index([status])
}

// ==================== EXTERNAL INVITATIONS (دعوة طرف خارجي) ====================

enum InvitationStatus {
  PENDING
  CONTACTED
  ACCEPTED
  DECLINED
  CLOSED
}

model ExternalInvitation {
  id                 String           @id @default(uuid())
  clientId           String
  client             User             @relation("ClientInvitations", fields: [clientId], references: [id])
  inviteeName        String
  inviteeEmail       String?
  inviteePhone       String?
  inviteeType        String?
  projectTitle       String
  field              String?
  projectDescription String
  budgetMin          Decimal?
  budgetMax          Decimal?
  durationDays       Int?
  message            String?
  status             InvitationStatus @default(PENDING)
  adminNote          String?
  token              String           @unique @default(uuid())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([clientId])
  @@index([status])
}

// ==================== REVIEWS & RATINGS (تقييمات ومراجعات) ====================

enum ReviewRole {
  CLIENT // تقييم كتبه العميل عن مقدّم الخدمة
  PROVIDER // تقييم كتبه مقدّم الخدمة عن العميل
}

model Review {
  id         String     @id @default(uuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id])
  authorId   String
  author     User       @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId   String
  target     User       @relation("ReviewTarget", fields: [targetId], references: [id])
  authorRole ReviewRole
  rating     Int
  comment    String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([projectId, authorId])
  @@index([targetId])
  @@index([projectId])
}
enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycIdType {
  NATIONAL_ID
  PASSPORT
  COMMERCIAL_REGISTER
}

model KycSubmission {
  id           String    @id @default(uuid())
  userId       String
  idType       KycIdType
  idNumber     String
  fullNameOnId String
  frontImage   String
  backImage    String?
  selfie       String?
  status       KycStatus @default(PENDING)
  reviewNote   String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}
model ProviderClient {
  id         String   @id @default(uuid())
  providerId String
  name       String
  company    String?
  email      String?
  phone      String?
  whatsapp   String?
  source     String?  // EXTERNAL | PLATFORM
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerId])
}
model ExternalProject {
  id          String    @id @default(uuid())
  providerId  String
  clientId    String?
  title       String
  description String?
  status      String    @default("IN_PROGRESS") // NEW | IN_PROGRESS | DONE | CANCELLED
  value       Decimal?
  currency    String?   @default("EGP")
  startDate   DateTime?
  dueDate     DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([providerId])
  @@index([clientId])
}
model ProviderInvoice {
  id         String    @id @default(uuid())
  providerId String
  clientId   String?
  number     String?
  title      String?
  status     String    @default("DRAFT") // DRAFT | SENT | PAID | CANCELLED
  currency   String?   @default("EGP")
  items      String?   // JSON: [{ desc, qty, price }]
  subtotal   Decimal?  @default(0)
  taxRate    Decimal?  @default(0)
  discount   Decimal?  @default(0)
  total      Decimal?  @default(0)
  notes      String?
  issueDate  DateTime?
  dueDate    DateTime?
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([providerId])
  @@index([clientId])
}
model ProviderWalletTransaction {
  id          String   @id @default(uuid())
  providerId  String
  type        String   // EARNING | ADJUSTMENT | WITHDRAWAL
  amount      Decimal
  currency    String?  @default("EGP")
  status      String   @default("COMPLETED") // PENDING | COMPLETED | CANCELLED
  method      String?  // للسحب: bank | instapay | wallet ...
  description String?
  refType     String?  // INVOICE | MANUAL ...
  refId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([providerId])
}
model ProviderTask {
  id          String    @id @default(uuid())
  providerId  String
  title       String
  description String?
  status      String    @default("TODO")    // TODO | DOING | DONE
  priority    String    @default("MEDIUM")  // LOW | MEDIUM | HIGH
  dueDate     DateTime?
  clientId    String?
  projectRef  String?   // ربط اختياري بمشروع (منصة/خارجي) بالعنوان أو المعرّف
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([providerId])
  @@index([clientId])
}
model ProviderBusinessSettings {
  id                  String   @id @default(uuid())
  providerId          String   @unique
  businessName        String?
  logoUrl             String?
  address             String?
  taxNumber           String?
  phone               String?
  email               String?
  website             String?
  defaultCurrency     String?  @default("EGP")
  defaultTaxRate      Decimal? @default(0)
  defaultPaymentTerms String?
  invoiceFooter       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([providerId])
}
model AdminNotification {
  id             String   @id @default(uuid())
  adminId        String
  adminName      String
  target         String
  role           String?
  recipientName  String?
  title          String
  body           String?
  linkUrl        String?
  recipientCount Int      @default(0)
  createdAt      DateTime @default(now())
}
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorName  String?
  actorRole  String?
  action     String
  method     String?
  path       String?
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
}
